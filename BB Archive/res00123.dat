<?xml version="1.0" encoding="UTF-8"?>
<CONTENT id="_3793160_1"><TITLE value="Presentation"/><TITLECOLOR value="#000000"/><DESCRIPTION
   value=""/><BODY><TEXT>&lt;p&gt;This is the presentation for Session 10&lt;/p&gt;&lt;p&gt;&lt;img src="@X@EmbeddedFile.requestUrlStub@X@bbcswebdav/xid-43740565_1" alt="" width="125" height="101" style="border: 0px solid #000000;"&gt;&lt;/p&gt;&lt;p&gt;The process for an organization to obtaining a ISO27001:2022 compliance certification is set out in the following document&lt;br&gt;&lt;span style="font-size: 12pt;"&gt;&lt;strong&gt;&lt;a alt="" href="@X@EmbeddedFile.requestUrlStub@X@bbcswebdav/xid-54250626_1" target="_blank" rel="noopener"&gt;27001 Cheat Sheet.pdf&lt;/a&gt;&amp;nbsp; Open and read please!&lt;br&gt;&lt;/strong&gt;&lt;/span&gt;Notes:&lt;/p&gt;&lt;ol&gt;&lt;li&gt;There is a 2022 update to ISO27001 with organizations expected to comply with the updated standard by October 2025.&lt;/li&gt;&lt;li&gt;Apart from a successful checklist/audits/certification, the actual output of the ISO27001 process is a customised &lt;span style="font-size: 12pt;"&gt;&lt;strong&gt;Information Security Management System (ISMS)&lt;/strong&gt; &lt;span style="font-size: 10pt;"&gt;for that organization.&lt;br&gt;&lt;/span&gt;&lt;/span&gt;The ISMS consists of a complete set of cyber security policy and procedure documents.&lt;br&gt;These must be regularly reviewed and updated to keep ISO27001 compliance.&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;</TEXT><TYPE
   value="H"/></BODY><DATES><CREATED value="2023-07-24 13:40:45 AWST"/><UPDATED value="2025-04-08 08:18:12 AWST"/><START
   value=""/><END value=""/></DATES><FLAGS><ISAVAILABLE value="true"/><ISFROMCARTRIDGE value="false"/><ISFOLDER
   value="false"/><ISDESCRIBED value="false"/><ISTRACKED value="true"/><ISLESSON value="false"/><ISSEQUENTIAL
