188c6e9a7b8fc0a5f5,passes_tool_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,permissions_tool_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,content_add_alignment_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,content_tracking_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,content_versions_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,*separator*,*separator*,bookmarkId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,itemsId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,packagesId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,emailId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,removeContentFolderId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,*separator*,copyContentId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,moveContentId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,*separator*,removeContentId_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,*separator*,Metadata_General_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,Metadata_Dublin_Core_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,Metadata_IMS_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5,Metadata_Full_IMS_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5," bb:overwritenavitems="" bb:beforeshowfunc=""&gt;&lt;a id="cmlink_ddcea3c6ad8c4a188c6e9a7b8fc0a5f5" role="button" href="@X@EmbeddedFile.requestUrlStub@X@webapps/blackboard/content/listContentEditable.jsp?content_id=_2690459_1&amp;amp;course_id=_26269_1#contextMenu" title="Click for more options"&gt;&lt;img style="height: 14px; width: 16px;" src="https://learn.content.blackboardcdn.com/3900.19.0-rel.38+a5c3f13/images/ci/icons/cmlink_generic.gif" alt="Click for more options"&gt;&lt;/a&gt;&lt;/span&gt;&lt;br&gt;&amp;nbsp;&lt;/li&gt;&#xd;
&lt;/ol&gt;&#xd;
&lt;div&gt;&lt;strong&gt;&lt;em&gt;Any submissions not meeting the above requirements will be rejected. All submissions must be demonstrably, clearly and unquestionably your work; any question of authenticity will result in the rejection of submissions.&amp;nbsp;&lt;/em&gt;&lt;/strong&gt;&amp;nbsp;&lt;strong&gt;&lt;em&gt;There is a zero tolerance plagiarism policy enforced.&lt;/em&gt;&lt;/strong&gt;&lt;/div&gt;&#xd;
&lt;div&gt;If you have any questions, please do not hesitate to ask your lecturer either in person or over email (see the contacts section of BlackBoard).&lt;/div&gt;</TEXT><TYPE
